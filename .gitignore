# ============================================================================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
*.sublime-project
*.sublime-workspace

# ============================================================================
# AWS & Credential Files
# ============================================================================
.aws/
aws_credentials
aws_config

# ============================================================================
# Logs & Crash Files
# ============================================================================
*.log
crash.log
crash.*.log

# ============================================================================
# Temporary Files
# ============================================================================
*.tmp
*.temp
.backup/
*.bak

# ============================================================================
# Environment Files
# ============================================================================
.env
.env.local
.env.*.local
